{
  "name": "@mokshavoice/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc && echo 'Build complete'",
    "start": "node dist/apps/backend/src/server.js",
    "start:prod": "prisma migrate deploy && node dist/apps/backend/src/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/cloudfront-signer": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@mokshavoice/shared-types": "workspace:*",
    "@prisma/client": "^5.15.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.8.0",
    "date-fns": "^3.6.0",
    "fastify": "^4.28.1",
    "firebase-admin": "^12.2.0",
    "ioredis": "^5.4.1",
    "socket.io": "^4.7.5",
    "stripe": "^15.12.0",
    "undici": "^6.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.15.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
