# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:8081,https://mokshavoice.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mokshavoice:mokshavoice_dev@localhost:5432/mokshavoice

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_32_plus_char_random_secret_here_xxxxxxxxxxxx
JWT_REFRESH_SECRET=replace_with_different_32_plus_char_secret_here_xxxxx

# ── Firebase (service account — server-side only) ─────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# ── AWS / S3 / CloudFront ─────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=mokshavoice-audio
CLOUDFRONT_DOMAIN=https://d1234abcdef.cloudfront.net
# From AWS Console → CloudFront → Key Management → Public Keys
CLOUDFRONT_KEY_PAIR_ID=APKAXXXXXXXXXXXXXXXXX
# RSA-2048 private key — paste with literal \n between lines (no actual newlines in .env)
CLOUDFRONT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Server-side secret key (never expose to mobile)
RC_SECRET_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret — set in RC Dashboard → Project Settings → Webhooks
RC_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (web payments fallback) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
