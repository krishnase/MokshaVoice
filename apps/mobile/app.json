{
  "expo": {
    "name": "MokshaVoice",
    "slug": "mokshavoice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mokshavoice",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1F3D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mokshavoice.app",
      "googleServicesFile": "./ios/MokshaVoice/GoogleService-Info.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MokshaVoice needs microphone access to record your dream descriptions.",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.mokshavoice.app",
      "versionCode": 2,
      "usesCleartextTraffic": true,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1F3D"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F47C20"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "./plugins/withModularHeaders"
    ],
    "platforms": [
      "ios",
      "android"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "312e16ea-7207-4066-8d46-1e7be8f6068c"
      }
    },
    "owner": "mokshavoice"
  }
}
