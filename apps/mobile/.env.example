# ── API ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── RevenueCat (public keys — safe to include in app bundle) ──────────────────
# For sandbox/testing use the test_ key for both platforms
# For production use separate appl_ (iOS) and goog_ (Android) keys from RC dashboard
EXPO_PUBLIC_RC_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_RC_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase (client-side config — public) ───────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:ios:xxxxxxxxxxxxxxxxxx
